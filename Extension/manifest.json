{
  "manifest_version": 3,
  "name": "CookieEdit (2CongLC)",
  "version": "1.0.0",
  "description": "Xem, sửa, thêm, xoá cookie của tab đang mở. Xuất/nhập cookie dạng JSON.",
  "permissions": ["cookies", "activeTab", "tabs"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "CookieEdit",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
